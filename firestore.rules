rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model: posts
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - publishedAt: timestamp (required)
    //   - createdAt: timestamp (required, on create)
    //   - updatedAt: timestamp (required)
    //
    // Auth model: Local auth (browser-side). Firebase Auth not used.
    // Security is enforced at the application layer.
    // Firestore rules validate data structure only.
    // ===============================================================

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'publishedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 100000 &&
             data.publishedAt is timestamp &&
             (!data.keys().hasAny(['photoUrl']) || data.photoUrl is string);
    }

    match /posts/{postId} {
      // Publicly readable
      allow read: if true;

      // Write allowed for anyone who sends valid data.
      // Access control is handled by the application's local auth layer.
      allow create: if isValidPost(request.resource.data);
      allow update: if isValidPost(request.resource.data);
      allow delete: if true;
    }
  }
}
